<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="8dp"
    android:paddingVertical="12dp">

    <!-- Corner Radius -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="8dp"
        android:text="@string/lg_corner_label"
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <com.google.android.material.slider.Slider
        android:id="@+id/slider_lg_corner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stepSize="1.0"
        android:valueFrom="0"
        android:valueTo="99"
        app:labelBehavior="floating"
        app:tickVisibilityMode="hidden" />

    <!-- Refraction Height -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="8dp"
        android:text="@string/lg_refraction_height_label"
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <com.google.android.material.slider.Slider
        android:id="@+id/slider_lg_refraction_height"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stepSize="1.0"
        android:valueFrom="12"
        android:valueTo="50"
        app:labelBehavior="floating"
        app:tickVisibilityMode="hidden" />

    <!-- Refraction Offset -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="8dp"
        android:text="@string/lg_refraction_offset_label"
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <com.google.android.material.slider.Slider
        android:id="@+id/slider_lg_refraction_offset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stepSize="1.0"
        android:valueFrom="20"
        android:valueTo="120"
        app:labelBehavior="floating"
        app:tickVisibilityMode="hidden" />

    <!-- Blur Radius -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="8dp"
        android:text="@string/lg_blur_radius_label"
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <com.google.android.material.slider.Slider
        android:id="@+id/slider_lg_blur_radius"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stepSize="1.0"
        android:valueFrom="0"
        android:valueTo="50"
        app:labelBehavior="floating"
        app:tickVisibilityMode="hidden" />

    <!-- Dispersion -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="8dp"
        android:text="@string/lg_dispersion_label"
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <com.google.android.material.slider.Slider
        android:id="@+id/slider_lg_dispersion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="0.0"
        android:valueTo="1.0"
        app:labelBehavior="floating"
        app:tickVisibilityMode="hidden" />

</LinearLayout>
