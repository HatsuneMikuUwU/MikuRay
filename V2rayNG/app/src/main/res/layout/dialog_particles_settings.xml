<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="8dp"
        android:paddingVertical="12dp">

        <!-- Frame delay -->
        <TextView
            android:id="@+id/text_label_frame_delay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />
        <com.google.android.material.slider.Slider
            android:id="@+id/slider_frame_delay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:labelBehavior="floating"
            app:tickVisibilityMode="hidden" />

        <!-- Line length -->
        <TextView
            android:id="@+id/text_label_line_length"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:layout_marginTop="8dp"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />
        <com.google.android.material.slider.Slider
            android:id="@+id/slider_line_length"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:labelBehavior="floating"
            app:tickVisibilityMode="hidden" />

        <!-- Line thickness -->
        <TextView
            android:id="@+id/text_label_line_thickness"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:layout_marginTop="8dp"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />
        <com.google.android.material.slider.Slider
            android:id="@+id/slider_line_thickness"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:labelBehavior="floating"
            app:tickVisibilityMode="hidden" />

        <!-- Particle radius max -->
        <TextView
            android:id="@+id/text_label_radius_max"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:layout_marginTop="8dp"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />
        <com.google.android.material.slider.Slider
            android:id="@+id/slider_radius_max"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:labelBehavior="floating"
            app:tickVisibilityMode="hidden" />

        <!-- Particle radius min -->
        <TextView
            android:id="@+id/text_label_radius_min"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:layout_marginTop="8dp"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />
        <com.google.android.material.slider.Slider
            android:id="@+id/slider_radius_min"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:labelBehavior="floating"
            app:tickVisibilityMode="hidden" />

        <!-- Density -->
        <TextView
            android:id="@+id/text_label_density"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:layout_marginTop="8dp"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />
        <com.google.android.material.slider.Slider
            android:id="@+id/slider_density"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:labelBehavior="floating"
            app:tickVisibilityMode="hidden" />

        <!-- Speed factor -->
        <TextView
            android:id="@+id/text_label_speed_factor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:layout_marginTop="8dp"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />
        <com.google.android.material.slider.Slider
            android:id="@+id/slider_speed_factor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:labelBehavior="floating"
            app:tickVisibilityMode="hidden" />

    </LinearLayout>

</ScrollView>
