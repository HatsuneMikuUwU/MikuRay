<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="72dp"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    app:cardBackgroundColor="?colorSurfaceContainerHighest"
    app:cardCornerRadius="99dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingVertical="18dp">

        <TextView
            android:id="@+id/tvDailyMax"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?textAppearanceBodyLarge"
            android:textColor="?colorOnSurface"
            tools:text="30°" />

        <TextView
            android:id="@+id/tvDailyMin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textAppearance="?textAppearanceBodyLarge"
            android:textColor="?colorOnSurfaceVariant"
            tools:text="24°" />

        <ImageView
            android:id="@+id/ivDailyIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginBottom="8dp"
            tools:src="@drawable/ic_weather_sunny" />

        <TextView
            android:id="@+id/tvDailyPrecip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:textAppearance="?textAppearanceLabelMedium"
            android:textColor="?colorPrimary"
            tools:text="20%" />

        <TextView
            android:id="@+id/tvDailyWeekday"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?textAppearanceLabelMedium"
            android:textColor="?colorOnSurface"
            tools:text="Sen" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
